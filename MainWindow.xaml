<Window x:Class="RegexBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:RegexBuilder.ViewModels"
        mc:Ignorable="d"
        Title="{DynamicResource Title}" 
        Height="800" Width="1350"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}"
        FontFamily="{StaticResource MainFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <Style x:Key="HeaderTextBlock" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Gold}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <Style x:Key="BrickButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <viewModels:MainViewModel x:Name="ViewModel"/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR (App Header & Language Selector) -->
        <Border Grid.Row="0" Background="#171718" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Regex" Foreground="{StaticResource Gold}" FontSize="18" FontWeight="Bold" FontFamily="{StaticResource MainFont}"/>
                    <TextBlock Text="Builder" Foreground="{StaticResource Blue}" FontSize="18" FontWeight="Bold" FontFamily="{StaticResource MainFont}"/>
                    <TextBlock Text=" v1.0" Foreground="#55555A" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,3"/>
                </StackPanel>

                <!-- Language Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnLangRu" Content="RU" Click="OnLanguageRuClick" Width="36" Height="24" Margin="0,0,5,0" Style="{StaticResource GoldButton}" Padding="0" FontSize="11" FontWeight="Bold"/>
                    <Button x:Name="BtnLangEn" Content="EN" Click="OnLanguageEnClick" Width="36" Height="24" Style="{StaticResource {x:Type Button}}" Padding="0" FontSize="11" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT (Row 1) -->
        <Grid Grid.Row="1">
            <!-- Main Column Layout -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL (Width = 350) -->
            <Grid Grid.Column="0" Background="{StaticResource PanelBg}" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="250" />
                </Grid.RowDefinitions>

                <!-- Tabs Control (Row 0) -->
                <TabControl Grid.Row="0" Margin="5">
                    <!-- Tab 1: Constructor -->
                    <TabItem Header="{DynamicResource TabConstructor}">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ConstructorHelp}" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               TextWrapping="Wrap" 
                                               Margin="0,0,0,10" 
                                               FontSize="11" />
                                    
                                    <TextBlock Text="{DynamicResource CategoryChars}" Foreground="{StaticResource Blue}" Margin="0,5,0,3" FontWeight="SemiBold"/>
                                    <WrapPanel>
                                        <Button Content="\d" Tag="\d" Style="{StaticResource BrickButton}" ToolTip="Цифра (0-9)" Click="OnBrickClick"/>
                                        <Button Content="\D" Tag="\D" Style="{StaticResource BrickButton}" ToolTip="Не цифра" Click="OnBrickClick"/>
                                        <Button Content="\w" Tag="\w" Style="{StaticResource BrickButton}" ToolTip="Буква, цифра или подчеркивание" Click="OnBrickClick"/>
                                        <Button Content="\W" Tag="\W" Style="{StaticResource BrickButton}" ToolTip="Не буква и не цифра" Click="OnBrickClick"/>
                                        <Button Content="\s" Tag="\s" Style="{StaticResource BrickButton}" ToolTip="Пробел, таб, перевод строки" Click="OnBrickClick"/>
                                        <Button Content="\S" Tag="\S" Style="{StaticResource BrickButton}" ToolTip="Любой символ, кроме пробела" Click="OnBrickClick"/>
                                        <Button Content="." Tag="." Style="{StaticResource BrickButton}" ToolTip="Любой одиночный символ" Click="OnBrickClick"/>
                                    </WrapPanel>

                                    <TextBlock Text="{DynamicResource CategoryBoundaries}" Foreground="{StaticResource Blue}" Margin="0,10,0,3" FontWeight="SemiBold"/>
                                    <WrapPanel>
                                        <Button Content="^" Tag="^" Style="{StaticResource BrickButton}" ToolTip="Начало строки" Click="OnBrickClick"/>
                                        <Button Content="$" Tag="$" Style="{StaticResource BrickButton}" ToolTip="Конец строки" Click="OnBrickClick"/>
                                        <Button Content="\b" Tag="\b" Style="{StaticResource BrickButton}" ToolTip="Граница слова" Click="OnBrickClick"/>
                                        <Button Content="\B" Tag="\B" Style="{StaticResource BrickButton}" ToolTip="Не граница слова" Click="OnBrickClick"/>
                                    </WrapPanel>

                                    <TextBlock Text="{DynamicResource CategoryQuantifiers}" Foreground="{StaticResource Blue}" Margin="0,10,0,3" FontWeight="SemiBold"/>
                                    <WrapPanel>
                                        <Button Content="*" Tag="*" Style="{StaticResource BrickButton}" ToolTip="0 или более раз" Click="OnBrickClick"/>
                                        <Button Content="+" Tag="+" Style="{StaticResource BrickButton}" ToolTip="1 или более раз" Click="OnBrickClick"/>
                                        <Button Content="?" Tag="?" Style="{StaticResource BrickButton}" ToolTip="0 или 1 раз" Click="OnBrickClick"/>
                                        <Button Content="{}{n}" Tag="{}{n}" Style="{StaticResource BrickButton}" ToolTip="Ровно n раз" Click="OnBrickClick"/>
                                        <Button Content="{}{n,m}" Tag="{}{n,m}" Style="{StaticResource BrickButton}" ToolTip="От n до m раз" Click="OnBrickClick"/>
                                    </WrapPanel>

                                    <TextBlock Text="{DynamicResource CategoryGroups}" Foreground="{StaticResource Blue}" Margin="0,10,0,3" FontWeight="SemiBold"/>
                                    <WrapPanel>
                                        <Button Content="( )" Tag="()" Style="{StaticResource BrickButton}" ToolTip="Группа захвата" Click="OnBrickClick"/>
                                        <Button Content="(?: )" Tag="(?:)" Style="{StaticResource BrickButton}" ToolTip="Группа без захвата" Click="OnBrickClick"/>
                                        <Button Content="(?&lt;name&gt; )" Tag="(?&lt;name&gt;)" Style="{StaticResource BrickButton}" ToolTip="Именованная группа" Click="OnBrickClick"/>
                                        <Button Content="|" Tag="|" Style="{StaticResource BrickButton}" ToolTip="ИЛИ" Click="OnBrickClick"/>
                                    </WrapPanel>

                                    <TextBlock Text="{DynamicResource CategoryClasses}" Foreground="{StaticResource Blue}" Margin="0,10,0,3" FontWeight="SemiBold"/>
                                    <WrapPanel>
                                        <Button Content="[a-z]" Tag="[a-z]" Style="{StaticResource BrickButton}" ToolTip="Символ из диапазона a-z" Click="OnBrickClick"/>
                                        <Button Content="[^a-z]" Tag="[^a-z]" Style="{StaticResource BrickButton}" ToolTip="Символ НЕ из диапазона a-z" Click="OnBrickClick"/>
                                        <Button Content="[0-9]" Tag="[0-9]" Style="{StaticResource BrickButton}" ToolTip="Цифра от 0 до 9" Click="OnBrickClick"/>
                                        <Button Content="[а-я]" Tag="[а-я]" Style="{StaticResource BrickButton}" ToolTip="Русская буква" Click="OnBrickClick"/>
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- Tab 2: Testing -->
                    <TabItem Header="{DynamicResource TabTesting}">
                        <Grid Margin="0,5,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource TestingTitle}" 
                                           Foreground="{StaticResource Gold}" 
                                           FontWeight="SemiBold" 
                                           Margin="0,0,0,10"/>
                                
                                <TextBlock Text="{DynamicResource ReplaceWithLabel}" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ReplacePattern, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource MonoTextBox}"
                                         Margin="0,0,0,15"
                                         Padding="6"/>

                                <TextBlock Text="{DynamicResource ReplacementResultLabel}" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding ReplacementResult, Mode=OneWay}" 
                                         Style="{StaticResource MonoTextBox}"
                                         Height="220"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#171718"
                                         Foreground="{StaticResource Gold}"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- Tab 3: Favorites -->
                    <TabItem Header="{DynamicResource TabFavorites}">
                        <Grid>
                            <ListBox x:Name="FavoritesListBox"
                                     ItemsSource="{Binding Favorites}" 
                                     SelectedItem="{Binding SelectedFavorite}"
                                     HorizontalContentAlignment="Stretch"
                                     Margin="0,5,0,0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                        <EventSetter Event="MouseDoubleClick" Handler="OnFavoriteDoubleClick"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource Gold}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Pattern}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#666669" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" 
                                                    Content="✕" 
                                                    Command="{Binding DataContext.DeleteFavoriteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" 
                                                    BorderBrush="Transparent"
                                                    Foreground="#9E2A2A" 
                                                    FontWeight="Bold"
                                                    Padding="6,2"
                                                    VerticalAlignment="Center"
                                                    ToolTip="{DynamicResource DeleteFavoriteTooltip}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Background="{StaticResource Border}" Margin="5,0"/>

                <!-- Template Library (Row 2) -->
                <Grid Grid.Row="2" Margin="10,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{DynamicResource LibraryHeader}" Style="{StaticResource HeaderTextBlock}" Foreground="{StaticResource Gold}"/>
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Templates}" 
                             SelectedItem="{Binding SelectedTemplate}"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <EventSetter Event="MouseDoubleClick" Handler="OnTemplateDoubleClick"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2" ToolTip="{Binding Description}">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Pattern}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>

            <!-- SPLITTER 1 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- CENTER PANEL (*) -->
            <Grid Grid.Column="2" Background="{StaticResource PanelBg}" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="40" />
                </Grid.RowDefinitions>

                <!-- Editor Grid (Row 0) -->
                <Grid Grid.Row="0" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Line Numbers (Column 0) -->
                    <ScrollViewer Grid.Column="0" 
                                  x:Name="LineNumbersScrollViewer" 
                                  VerticalScrollBarVisibility="Hidden" 
                                  HorizontalScrollBarVisibility="Hidden" 
                                  Background="#171718"
                                  BorderThickness="1,1,0,1"
                                  BorderBrush="{StaticResource Border}">
                        <TextBlock x:Name="LineNumbersTextBlock" 
                                   Text="1" 
                                   FontFamily="{StaticResource MonoFont}" 
                                   FontSize="13" 
                                   Foreground="#55555A" 
                                   Padding="8,10,8,8"
                                   TextAlignment="Right" 
                                   LineHeight="19" />
                    </ScrollViewer>

                    <!-- Target Text Input / Highlight Container (Column 1) -->
                    <RichTextBox Grid.Column="1" 
                                 x:Name="TargetRichTextBox" 
                                 Style="{StaticResource {x:Type RichTextBox}}"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" 
                                 HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.ScrollChanged="OnRichTextBoxScrollChanged"
                                 TextChanged="OnRichTextBoxTextChanged"
                                 PreviewKeyDown="OnEditorPreviewKeyDown"
                                 BorderThickness="0,1,1,1"
                                 Background="#1E1E1E"
                                 Padding="5,10,8,8">
                        <FlowDocument LineHeight="19">
                            <Paragraph/>
                        </FlowDocument>
                    </RichTextBox>
                </Grid>

                <!-- Horizontal Splitter -->
                <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="{StaticResource Border}" Margin="10,0"/>

                <!-- Statistics Panel (Row 2) -->
                <Grid Grid.Row="2" Background="#171718" Margin="10,0,10,10" VerticalAlignment="Center">
                    <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Padding="10,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource Gold}" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource StatMatches}" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding MatchCount}" Foreground="{StaticResource Gold}" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource Blue}" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource StatTime}" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding ExecutionTime, StringFormat={}{0:F2} мс}" Foreground="{StaticResource Blue}" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="Green" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource StatGroups}" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding GroupCount}" Foreground="LightGreen" FontWeight="Bold"/>
                            </StackPanel>

                            <!-- Keyboard Shortcut Hint -->
                            <TextBlock Grid.Column="4" 
                                       Text="{DynamicResource ShortcutsHint}" 
                                       Foreground="#55555A" 
                                       FontSize="11" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- SPLITTER 2 -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- RIGHT PANEL (Width = 300) -->
            <Grid Grid.Column="4" Background="{StaticResource PanelBg}" Margin="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="{DynamicResource EditorHeader}" Style="{StaticResource HeaderTextBlock}"/>

                        <!-- Regex Editor TextBox -->
                        <TextBox x:Name="RegexInputTextBox" 
                                 Text="{Binding RegexPattern, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MonoTextBox}"
                                 Height="90" 
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap" 
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,10"/>

                        <!-- Flags Layout -->
                        <TextBlock Text="{DynamicResource FlagsHeader}" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Row="0" Grid.Column="0" Content="IgnoreCase" IsChecked="{Binding IgnoreCase}" Margin="0,3" ToolTip="Игнорировать регистр символов"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" Content="Multiline" IsChecked="{Binding Multiline}" Margin="0,3" ToolTip="Символы ^ и $ соответствуют началу и концу каждой строки"/>
                            <CheckBox Grid.Row="1" Grid.Column="0" Content="Singleline" IsChecked="{Binding Singleline}" Margin="0,3" ToolTip="Точка . соответствует абсолютно любому символу, включая новую строку"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" Content="IgnoreSpace" IsChecked="{Binding IgnorePatternWhitespace}" Margin="0,3" ToolTip="Игнорировать неэкранированные пробелы в паттерне"/>
                        </Grid>

                        <!-- Magic Generate Button -->
                        <Button Content="{DynamicResource BtnMagic}" 
                                Click="OnCreateRegexFromSelectionClick"
                                Style="{StaticResource GoldButton}" 
                                Height="38" 
                                FontWeight="Bold" 
                                Margin="0,0,0,15"
                                ToolTip="Выделите текст в центральном поле и нажмите кнопку для генерации паттерна (Ctrl+Enter)"/>

                        <GridSplitter Height="1" HorizontalAlignment="Stretch" Background="{StaticResource Border}" Margin="0,0,0,15"/>

                        <!-- Information Block -->
                        <TextBlock Text="{DynamicResource InfoBlockHeader}" Style="{StaticResource HeaderTextBlock}"/>
                        <Border BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4" Background="#171718" Padding="10" MinHeight="100" Margin="0,0,0,15">
                            <TextBlock Text="{Binding SelectedPatternDetails}" 
                                       Foreground="{StaticResource TextPrimary}" 
                                       TextWrapping="Wrap" 
                                       FontSize="12" 
                                       LineHeight="17"/>
                        </Border>

                        <Button Content="{DynamicResource BtnCopy}" 
                                Command="{Binding CopyRegexCommand}" 
                                Style="{StaticResource BlueButton}" 
                                Margin="0,0,0,10"
                                Padding="0,8"/>

                        <Button Content="{DynamicResource BtnSave}" 
                                Command="{Binding OpenSaveDialogCommand}" 
                                Style="{StaticResource {x:Type Button}}" 
                                Padding="0,8"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- OVERLAY 1: Save Favorite Dialog -->
        <Grid x:Name="SaveFavoriteOverlay"
              Grid.RowSpan="2"
              Background="#C0000000"
              Visibility="{Binding IsSaveDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource Gold}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="400"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="{DynamicResource SaveDialogTitle}" 
                               Foreground="{StaticResource Gold}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Margin="0,0,0,15"/>

                    <TextBlock Text="{DynamicResource SaveDialogName}" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewFavoriteName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource {x:Type TextBox}}"
                             Margin="0,0,0,15"
                             Padding="8,6"/>

                    <TextBlock Text="{DynamicResource SaveDialogDesc}" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewFavoriteDescription, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource {x:Type TextBox}}"
                             Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,20"
                             Padding="8,6"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" 
                                Content="{DynamicResource BtnSaveConfirm}" 
                                Command="{Binding SaveFavoriteCommand}" 
                                Style="{StaticResource GoldButton}"
                                Padding="0,8"/>
                        <Button Grid.Column="2" 
                                Content="{DynamicResource BtnCancel}" 
                                Command="{Binding CloseSaveDialogCommand}"
                                Padding="0,8"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- OVERLAY 2: Syntax Help (F1) -->
        <Grid x:Name="SyntaxHelpOverlay"
              Grid.RowSpan="2"
              Background="#C0000000"
              Visibility="{Binding IsSyntaxHelpOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{StaticResource PanelBg}"
                    BorderBrush="{StaticResource Blue}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="550"
                    Height="500"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="{DynamicResource HelpTitle}" 
                               Foreground="{StaticResource Blue}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource HelpSecChars}" FontWeight="Bold" Foreground="{StaticResource Gold}" Margin="0,5,0,2"/>
                            <TextBlock Text="{DynamicResource HelpSecCharsBody}" 
                                       Foreground="{StaticResource TextPrimary}" Margin="10,0,0,10" FontFamily="{StaticResource MonoFont}" LineHeight="17"/>

                            <TextBlock Text="{DynamicResource HelpSecQuant}" FontWeight="Bold" Foreground="{StaticResource Gold}" Margin="0,5,0,2"/>
                            <TextBlock Text="{DynamicResource HelpSecQuantBody}" 
                                       Foreground="{StaticResource TextPrimary}" Margin="10,0,0,10" FontFamily="{StaticResource MonoFont}" LineHeight="17"/>

                            <TextBlock Text="{DynamicResource HelpSecBounds}" FontWeight="Bold" Foreground="{StaticResource Gold}" Margin="0,5,0,2"/>
                            <TextBlock Text="{DynamicResource HelpSecBoundsBody}" 
                                       Foreground="{StaticResource TextPrimary}" Margin="10,0,0,10" FontFamily="{StaticResource MonoFont}" LineHeight="17"/>

                            <TextBlock Text="{DynamicResource HelpSecGroups}" FontWeight="Bold" Foreground="{StaticResource Gold}" Margin="0,5,0,2"/>
                            <TextBlock Text="{DynamicResource HelpSecGroupsBody}" 
                                       Foreground="{StaticResource TextPrimary}" Margin="10,0,0,10" FontFamily="{StaticResource MonoFont}" LineHeight="17"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="2" 
                            Content="{DynamicResource BtnClose}" 
                            Command="{Binding ToggleSyntaxHelpCommand}" 
                            HorizontalAlignment="Right"
                            Style="{StaticResource BlueButton}"
                            Padding="15,8"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
